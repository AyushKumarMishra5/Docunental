# DocuIntel - Production Environment Configuration Guide

# ============================================================================
# ESSENTIAL ENVIRONMENT VARIABLES FOR PRODUCTION DEPLOYMENT
# ============================================================================

# ----------------------------------------------------------------------------
# DATABASE CONFIGURATION (REQUIRED)
# ----------------------------------------------------------------------------

# MongoDB Atlas Connection String
# Get this from: https://cloud.mongodb.com/ → Your Cluster → Connect
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/docuintel?retryWrites=true&w=majority

# Example (REPLACE WITH YOUR ACTUAL CREDENTIALS):
# MONGODB_URI=mongodb+srv://docuentel:docuentel@hms.j0zylph.mongodb.net/docuintel?retryWrites=true&w=majority


# ----------------------------------------------------------------------------
# AI/LLM CONFIGURATION (REQUIRED)
# ----------------------------------------------------------------------------

# OpenRouter API Key
# Get free key from: https://openrouter.ai/
# Free tier includes access to multiple models
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# OpenRouter Model Selection
# Options:
# - openrouter/free (Auto-routes to best free model - RECOMMENDED)
# - nvidia/nemotron-3-ultra-550b-a55b:free (1M context, free)
# - google/gemma-4-31b-it:free (262K context, free)
# - For production: anthropic/claude-3-5-sonnet (paid, best quality)
OPENROUTER_MODEL=openrouter/free


# ----------------------------------------------------------------------------
# APPLICATION MODE (REQUIRED)
# ----------------------------------------------------------------------------

# Use production mode (0 = production with real AI, 1 = mock/testing)
USE_MOCK=0


# ----------------------------------------------------------------------------
# NEXTJS CONFIGURATION (REQUIRED FOR PRODUCTION)
# ----------------------------------------------------------------------------

# Production URL (your domain)
NEXT_PUBLIC_APP_URL=https://yourdomain.com

# Node Environment
NODE_ENV=production

# Application Port (default: 3000)
PORT=3000


# ----------------------------------------------------------------------------
# STORAGE CONFIGURATION (OPTIONAL)
# ----------------------------------------------------------------------------

# Option 1: Local Filesystem Storage (Default)
LOCAL_STORAGE_PATH=./.docuintel/storage

# Option 2: Cloudflare R2 Storage (Recommended for production)
# Get credentials from: https://dash.cloudflare.com/ → R2
# Uncomment and configure if using R2:
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=your_r2_access_key_id
# R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=docuintel-documents

# Option 3: AWS S3 Storage (Alternative)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=your_aws_access_key
# AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# AWS_S3_BUCKET=docuintel-documents


# ----------------------------------------------------------------------------
# SECURITY CONFIGURATION (RECOMMENDED FOR PRODUCTION)
# ----------------------------------------------------------------------------

# JWT Secret for session encryption
# Generate: openssl rand -base64 32
JWT_SECRET=your_random_secret_key_here_min_32_chars

# Session Cookie Secret
# Generate: openssl rand -base64 32
SESSION_SECRET=another_random_secret_key_here

# CORS Allowed Origins (comma-separated)
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Rate Limiting
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000


# ----------------------------------------------------------------------------
# OPTIONAL: ANALYTICS & MONITORING
# ----------------------------------------------------------------------------

# Google Analytics
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Sentry Error Tracking
# SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx

# LogTail/BetterStack Logging
# LOGTAIL_SOURCE_TOKEN=your_logtail_token


# ----------------------------------------------------------------------------
# OPTIONAL: EMAIL NOTIFICATIONS (for alerts)
# ----------------------------------------------------------------------------

# SendGrid (for email notifications)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxx
# SENDGRID_FROM_EMAIL=noreply@yourdomain.com

# SMTP Alternative
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password


# ----------------------------------------------------------------------------
# OPTIONAL: AUTHENTICATION (if adding user accounts)
# ----------------------------------------------------------------------------

# NextAuth Configuration (if implementing user login)
# NEXTAUTH_URL=https://yourdomain.com
# NEXTAUTH_SECRET=your_nextauth_secret_key

# OAuth Providers (optional)
# GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=xxx
# GITHUB_CLIENT_ID=xxx
# GITHUB_CLIENT_SECRET=xxx


# ----------------------------------------------------------------------------
# OPTIONAL: FILE UPLOAD LIMITS
# ----------------------------------------------------------------------------

# Maximum file size in bytes (default: 10MB)
MAX_FILE_SIZE=10485760

# Maximum files per upload
MAX_FILES_PER_UPLOAD=10

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=pdf,docx,txt,md


# ----------------------------------------------------------------------------
# OPTIONAL: AI PROCESSING TIMEOUTS
# ----------------------------------------------------------------------------

# AI Analysis Timeout (milliseconds, default: 30000)
AI_ANALYSIS_TIMEOUT=30000

# AI Synthesis Timeout (milliseconds, default: 20000)
AI_SYNTHESIS_TIMEOUT=20000

# Document Processing Timeout (milliseconds, default: 120000)
DOCUMENT_PROCESSING_TIMEOUT=120000


# ----------------------------------------------------------------------------
# OPTIONAL: REDIS CACHE (for high-performance deployments)
# ----------------------------------------------------------------------------

# Redis URL for caching
# REDIS_URL=redis://localhost:6379
# or for Redis Cloud:
# REDIS_URL=redis://username:password@redis-host:port


# ============================================================================
# DEPLOYMENT PLATFORM SPECIFIC VARIABLES
# ============================================================================

# ----------------------------------------------------------------------------
# VERCEL DEPLOYMENT
# ----------------------------------------------------------------------------
# Vercel automatically sets NODE_ENV, PORT, and VERCEL_URL
# Add these in Vercel Dashboard → Settings → Environment Variables:
# - MONGODB_URI
# - OPENROUTER_API_KEY
# - OPENROUTER_MODEL
# - JWT_SECRET
# - SESSION_SECRET

# ----------------------------------------------------------------------------
# AWS / EC2 DEPLOYMENT
# ----------------------------------------------------------------------------
# Set environment variables in:
# - ~/.bashrc or ~/.profile
# - /etc/environment
# - PM2 ecosystem.config.js

# ----------------------------------------------------------------------------
# DOCKER DEPLOYMENT
# ----------------------------------------------------------------------------
# Pass environment variables via:
# - docker run -e MONGODB_URI=xxx -e OPENROUTER_API_KEY=xxx
# - docker-compose.yml environment section
# - .env file (same directory as docker-compose.yml)

# ----------------------------------------------------------------------------
# RAILWAY DEPLOYMENT
# ----------------------------------------------------------------------------
# Add in Railway Dashboard → Variables:
# All variables listed above

# ----------------------------------------------------------------------------
# HEROKU DEPLOYMENT
# ----------------------------------------------------------------------------
# Set via Heroku CLI:
# heroku config:set MONGODB_URI=xxx
# heroku config:set OPENROUTER_API_KEY=xxx


# ============================================================================
# SECURITY BEST PRACTICES
# ============================================================================

# 1. NEVER commit this file with real credentials to Git
# 2. Use different values for development and production
# 3. Rotate secrets regularly (every 90 days)
# 4. Use environment-specific .env files:
#    - .env.local (local development)
#    - .env.production (production)
#    - .env.staging (staging environment)
# 5. Use secret management services in production:
#    - AWS Secrets Manager
#    - HashiCorp Vault
#    - Azure Key Vault
#    - Vercel Environment Variables


# ============================================================================
# QUICK START CHECKLIST
# ============================================================================

# ✅ MINIMUM REQUIRED (to start the app):
# 1. MONGODB_URI - MongoDB connection string
# 2. OPENROUTER_API_KEY - AI processing
# 3. OPENROUTER_MODEL - AI model selection
# 4. USE_MOCK=0 - Enable production mode

# ✅ RECOMMENDED (for production):
# 5. NEXT_PUBLIC_APP_URL - Your domain
# 6. JWT_SECRET - Security
# 7. SESSION_SECRET - Security
# 8. NODE_ENV=production - Production mode

# ✅ OPTIONAL (for enterprise):
# 9. R2/S3 storage configuration
# 10. Email notification setup
# 11. Analytics integration
# 12. Error monitoring


# ============================================================================
# EXAMPLE: MINIMAL PRODUCTION .env
# ============================================================================

# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/docuintel
# OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxx
# OPENROUTER_MODEL=openrouter/free
# USE_MOCK=0
# NEXT_PUBLIC_APP_URL=https://yourdomain.com
# NODE_ENV=production
# JWT_SECRET=your_random_32_char_secret
# SESSION_SECRET=another_random_32_char_secret


# ============================================================================
# NEED HELP?
# ============================================================================

# MongoDB Setup:
# 1. Go to https://cloud.mongodb.com/
# 2. Create free cluster (M0 Sandbox)
# 3. Create database user
# 4. Whitelist IP (0.0.0.0/0 for any IP)
# 5. Get connection string

# OpenRouter Setup:
# 1. Go to https://openrouter.ai/
# 2. Sign up for free account
# 3. Generate API key
# 4. Use free models (no credit card required)

# Deployment Guides:
# - Vercel: https://vercel.com/docs/environment-variables
# - Railway: https://docs.railway.app/develop/variables
# - AWS: https://docs.aws.amazon.com/elasticbeanstalk/latest/dg/environments-cfg-softwaresettings.html
# - Docker: https://docs.docker.com/compose/environment-variables/
